{
  "element_plus_theme": {
    "--el-color-primary": "#409eff",
    "--el-color-success": "#67c23a",
    "--el-color-danger": "#f56c6c",
    "--el-color-warning": "#e6a23c",
    "--el-color-info": "#909399",
    "--el-border-radius-base": "4px",
    "--el-font-size-base": "14px",
    "--el-component-size": "36px"
  },
  "component_mappings": {
    "status_tags": { "active": "success", "inactive": "info", "error": "danger" },
    "form_label_width": "110px",
    "dialog_default_width": "50%",
    "table_stripe": true,
    "pagination_layout": "total, sizes, prev, pager, next, jumper"
  },
  "custom_colors": {
    "background": "#fff",
    "text_primary": "#24292f",
    "text_secondary": "#57606a",
    "text_tertiary": "#8b949e",
    "border": "#d0d7de",
    "surface": "#f6f8fa",
    "link": "#238636",
    "link_hover": "#1a7f37",
    "accent_blue": "#0969da",
    "accent_green": "#1a7f37",
    "accent_red": "#cf222e"
  },
  "code_theme": {
    "background": "#f6f8fa",
    "border": "#d0d7de",
    "keyword": "#cf222e",
    "string": "#0a3069",
    "comment": "#6e7781",
    "function": "#8250df",
    "number": "#0550ae"
  },
  "npm_colors": {
    "gradient_start": "#fb6056",
    "gradient_end": "#d63d83",
    "red": "#cb3837",
    "green": "#238636",
    "blue": "#0969da",
    "purple": "#8064a9",
    "yellow": "#f0c040",
    "teal": "#118c55"
  },
  "huawei_cloud_theme": {
    "primary": "#0066FF",
    "primary_hover": "#0052CC",
    "primary_active": "#003D99",
    "primary_bg": "#E6F0FF",
    "text_primary": "#1A1A1A",
    "text_secondary": "#666666",
    "text_tertiary": "#999999",
    "background": "#F5F7FA",
    "surface": "#FFFFFF",
    "table_header": "#FAFAFA",
    "border": "#E8E8E8",
    "hover": "#F0F0F0",
    "success": "#52C41A",
    "success_bg": "#F6FFED",
    "error": "#FF4D4F",
    "error_bg": "#FFF1F0",
    "warning": "#FA8C16",
    "warning_bg": "#FFF7E6",
    "border_radius": "4px",
    "shadow_card": "0 1px 2px rgba(0,0,0,0.05)",
    "shadow_dropdown": "0 2px 8px rgba(0,0,0,0.08)"
  },
  "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif"
}
